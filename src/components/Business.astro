---
import { translations } from "../i18n/translations";
import type { Language } from "../i18n/translations";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
---

<section id="business" class="py-20 bg-[var(--bg-secondary)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 data-i18="business.title" class="font-hero text-3xl md:text-4xl text-jcm-blue dark:text-jcm-cream mb-4">
        {t.business.title}
      </h2>
      <p data-i18="business.subtitle" class="font-subtitle text-xl text-[var(--text-secondary)] mb-4">
        {t.business.subtitle}
      </p>
      <div class="w-24 h-1 bg-jcm-red mx-auto"></div>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-jcm-red">
        <div class="w-16 h-16 bg-jcm-red/10 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h3 data-i18="business.cat0.title" class="font-hero text-xl text-jcm-blue dark:text-jcm-cream mb-4">
          {t.business.categories[0].title}
        </h3>
        <p data-i18="business.cat0.desc" class="font-body text-[var(--text-primary)]">
          {t.business.categories[0].description}
        </p>
      </div>
      
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-jcm-steel">
        <div class="w-16 h-16 bg-jcm-steel/10 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-jcm-steel" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 data-i18="business.cat1.title" class="font-hero text-xl text-jcm-blue dark:text-jcm-cream mb-4">
          {t.business.categories[1].title}
        </h3>
        <p data-i18="business.cat1.desc" class="font-body text-[var(--text-primary)]">
          {t.business.categories[1].description}
        </p>
      </div>
      
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300 border-t-4 border-jcm-burgundy">
        <div class="w-16 h-16 bg-jcm-burgundy/10 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-8 h-8 text-jcm-burgundy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 data-i18="business.cat2.title" class="font-hero text-xl text-jcm-blue dark:text-jcm-cream mb-4">
          {t.business.categories[2].title}
        </h3>
        <p data-i18="business.cat2.desc" class="font-body text-[var(--text-primary)]">
          {t.business.categories[2].description}
        </p>
      </div>
    </div>
  </div>
</section>
