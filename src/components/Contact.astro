---
import { translations } from "../i18n/translations";
import type { Language } from "../i18n/translations";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
---

<section id="contact" class="py-20 bg-[var(--bg-secondary)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 data-i18="contact.title" class="font-hero text-3xl md:text-4xl text-jcm-blue dark:text-jcm-cream mb-4">
        {t.contact.title}
      </h2>
      <p data-i18="contact.subtitle" class="font-subtitle text-xl text-[var(--text-secondary)] mb-4">
        {t.contact.subtitle}
      </p>
      <div class="w-24 h-1 bg-jcm-red mx-auto"></div>
    </div>
    
    <div class="max-w-4xl mx-auto text-center mb-12">
      <p data-i18="contact.description" class="font-body text-lg text-[var(--text-primary)] leading-relaxed">
        {t.contact.description}
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-12">
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg">
        <form class="space-y-6">
          <div>
            <label for="name" data-i18="contact.name" class="block font-body text-sm font-medium mb-2">{t.contact.name}</label>
            <input 
              type="text" 
              id="name" 
              class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-transparent font-body focus:outline-none focus:border-jcm-red focus:ring-1 focus:ring-jcm-red transition-colors"
            />
          </div>
          
          <div>
            <label for="email" data-i18="contact.email" class="block font-body text-sm font-medium mb-2">{t.contact.email}</label>
            <input 
              type="email" 
              id="email" 
              class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-transparent font-body focus:outline-none focus:border-jcm-red focus:ring-1 focus:ring-jcm-red transition-colors"
            />
          </div>
          
          <div>
            <label for="phone" data-i18="contact.phone" class="block font-body text-sm font-medium mb-2">{t.contact.phone}</label>
            <input 
              type="tel" 
              id="phone" 
              class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-transparent font-body focus:outline-none focus:border-jcm-red focus:ring-1 focus:ring-jcm-red transition-colors"
            />
          </div>
          
          <div>
            <label for="message" data-i18="contact.message" class="block font-body text-sm font-medium mb-2">{t.contact.message}</label>
            <textarea 
              id="message" 
              rows="4" 
              class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-transparent font-body focus:outline-none focus:border-jcm-red focus:ring-1 focus:ring-jcm-red transition-colors resize-none"
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            data-i18="contact.send"
            class="w-full font-cta px-8 py-4 bg-jcm-red hover:bg-jcm-red-dark text-white text-lg rounded transition-all duration-300 hover:shadow-lg hover:shadow-jcm-red/30"
          >
            {t.contact.send}
          </button>
        </form>
      </div>
      
      <div class="space-y-8">
        <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-jcm-red/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-hero text-lg text-jcm-blue dark:text-jcm-cream mb-2">{t.contact.address}</h3>
              <p class="font-body text-[var(--text-primary)]">Av. Principal #123, Ciudad, País</p>
            </div>
          </div>
        </div>
        
        <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-jcm-red/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-hero text-lg text-jcm-blue dark:text-jcm-cream mb-2">{t.contact.phone}</h3>
              <p class="font-body text-[var(--text-primary)]">+1 234 567 890</p>
            </div>
          </div>
        </div>
        
        <div class="bg-[var(--bg-primary)] p-8 rounded-lg shadow-lg">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-jcm-red/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-hero text-lg text-jcm-blue dark:text-jcm-cream mb-2">{t.contact.email}</h3>
              <p class="font-body text-[var(--text-primary)]">contacto@jcminc.com</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
