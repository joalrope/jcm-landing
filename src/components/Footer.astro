---
import { translations } from "../i18n/translations";
import type { Language } from "../i18n/translations";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
---

<footer class="bg-jcm-blue text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-6">
          <img src="/jcm-logo.png" alt="JCM Inc" class="h-16 w-auto" />
        </div>
        <p data-i18="footer.description" class="font-body text-jcm-cream/80">{t.footer.description}</p>
      </div>
      
      <div>
        <h3 data-i18="footer.quickLinks" class="font-hero text-lg mb-6">{t.footer.quickLinks}</h3>
        <ul class="space-y-3">
          <li><a href="#about" class="font-body text-jcm-cream/80 hover:text-jcm-red transition-colors">{t.nav.about}</a></li>
          <li><a href="#business" class="font-body text-jcm-cream/80 hover:text-jcm-red transition-colors">{t.nav.business}</a></li>
          <li><a href="#projects" class="font-body text-jcm-cream/80 hover:text-jcm-red transition-colors">{t.nav.projects}</a></li>
          <li><a href="#sustainability" class="font-body text-jcm-cream/80 hover:text-jcm-red transition-colors">{t.nav.sustainability}</a></li>
          <li><a href="#people" class="font-body text-jcm-cream/80 hover:text-jcm-red transition-colors">{t.nav.people}</a></li>
          <li><a href="#contact" class="font-body text-jcm-cream/80 hover:text-jcm-red transition-colors">{t.nav.contact}</a></li>
        </ul>
      </div>
      
      <div>
        <h3 data-i18="footer.contact" class="font-hero text-lg mb-6">{t.footer.contact}</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="font-body text-jcm-cream/80">Av. Principal #123, Ciudad, País</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="font-body text-jcm-cream/80">+1 234 567 890</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-jcm-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="font-body text-jcm-cream/80">contacto@jcminc.com</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/10 pt-8 text-center">
      <p class="font-body text-sm text-jcm-cream/60">
        © {new Date().getFullYear()} JCM Inc. {t.footer.rights}
      </p>
    </div>
  </div>
</footer>
