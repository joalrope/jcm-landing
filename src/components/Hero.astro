---
import { translations } from "../i18n/translations";
import type { Language } from "../i18n/translations";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
---

<section id="about" class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
  <div class="absolute inset-0 bg-jcm-blue dark:bg-[#0a1a2e]"></div>
  <div class="absolute inset-0 opacity-20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_var(--color-jcm-red)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,_var(--color-jcm-steel)_0%,_transparent_40%)]"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <div class="mb-6">
      <img src="/jcm-logo.png" alt="JCM Inc" class="mx-auto h-24 md:h-32 w-auto" />
    </div>
    <h1 data-i18="hero.title" class="font-hero text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight">
      {t.hero.title}
    </h1>
    <p data-i18="hero.subtitle" class="font-subtitle text-xl md:text-2xl text-jcm-cream mb-8 max-w-3xl mx-auto">
      {t.hero.subtitle}
    </p>
    <a href="#contact" data-i18="hero.cta" class="inline-block font-cta px-8 py-4 bg-jcm-red hover:bg-jcm-red-dark text-white text-lg rounded transition-all duration-300 hover:shadow-lg hover:shadow-jcm-red/30">
      {t.hero.cta}
    </a>
  </div>
  
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-8 h-8 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
