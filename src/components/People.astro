---
import { translations } from "../i18n/translations";
import type { Language } from "../i18n/translations";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];

const team = [
  {
    name: "Oscar Mario Gómez",
    position: ["CEO & Fundador", "CEO & Founder"],
    image: "/ceo-founder.jpeg",
  },
  {
    name: "María García",
    position: ["Directora de Operaciones", "Operations Director"],
    image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&auto=format&fit=crop",
  },
  {
    name: "Roberto Sánchez",
    position: ["Director de Ingeniería", "Engineering Director"],
    image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&auto=format&fit=crop",
  },
  {
    name: "Ana López",
    position: ["Directora de Proyectos", "Projects Director"],
    image: "https://images.unsplash.com/photo-1580489944761-15a19d654956?w=400&auto=format&fit=crop",
  },
];
---

<section id="people" class="py-20 bg-[var(--bg-primary)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 data-i18="people.title" class="font-hero text-3xl md:text-4xl text-jcm-blue dark:text-jcm-cream mb-4">
        {t.people.title}
      </h2>
      <p data-i18="people.subtitle" class="font-subtitle text-xl text-[var(--text-secondary)] mb-4">
        {t.people.subtitle}
      </p>
      <div class="w-24 h-1 bg-jcm-red mx-auto"></div>
    </div>
    
    <div class="max-w-4xl mx-auto text-center mb-12">
      <p data-i18="people.description" class="font-body text-lg text-[var(--text-primary)] leading-relaxed">
        {t.people.description}
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {team.map((member, index) => (
        <div class="group">
          <div class="relative overflow-hidden rounded-lg mb-4">
            <img 
              src={member.image} 
              alt={member.name}
              class="w-full h-72 object-cover transform group-hover:scale-105 transition-transform duration-500 grayscale group-hover:grayscale-0"
            />
          </div>
          <h3 class="font-hero text-lg text-jcm-blue dark:text-jcm-cream text-center">
            {member.name}
          </h3>
          <p data-i18={`people.member${index}.position`} class="font-body text-sm text-jcm-red text-center">
            {member.position[lang === "es" ? 0 : 1]}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
