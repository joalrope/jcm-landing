---
import { translations } from "../i18n/translations";
import type { Language } from "../i18n/translations";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang];
---

<section id="sustainability" class="py-20 bg-[var(--bg-secondary)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 data-i18="sustainability.title" class="font-hero text-3xl md:text-4xl text-jcm-blue dark:text-jcm-cream mb-4">
        {t.sustainability.title}
      </h2>
      <p data-i18="sustainability.subtitle" class="font-subtitle text-xl text-[var(--text-secondary)] mb-4">
        {t.sustainability.subtitle}
      </p>
      <div class="w-24 h-1 bg-jcm-red mx-auto"></div>
    </div>
    
    <div class="max-w-4xl mx-auto text-center mb-12">
      <p data-i18="sustainability.description" class="font-body text-lg text-[var(--text-primary)] leading-relaxed">
        {t.sustainability.description}
      </p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg text-center hover:shadow-xl transition-shadow duration-300">
        <div class="w-20 h-20 bg-jcm-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-jcm-steel" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 data-i18="sustainability.item0.title" class="font-hero text-xl text-jcm-blue dark:text-jcm-cream mb-4">
          {t.sustainability.items[0].title}
        </h3>
        <p data-i18="sustainability.item0.desc" class="font-body text-[var(--text-primary)]">
          {t.sustainability.items[0].description}
        </p>
      </div>
      
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg text-center hover:shadow-xl transition-shadow duration-300">
        <div class="w-20 h-20 bg-jcm-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-jcm-steel" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
          </svg>
        </div>
        <h3 data-i18="sustainability.item1.title" class="font-hero text-xl text-jcm-blue dark:text-jcm-cream mb-4">
          {t.sustainability.items[1].title}
        </h3>
        <p data-i18="sustainability.item1.desc" class="font-body text-[var(--text-primary)]">
          {t.sustainability.items[1].description}
        </p>
      </div>
      
      <div class="bg-[var(--bg-primary)] p-8 rounded-lg text-center hover:shadow-xl transition-shadow duration-300">
        <div class="w-20 h-20 bg-jcm-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-jcm-steel" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </div>
        <h3 data-i18="sustainability.item2.title" class="font-hero text-xl text-jcm-blue dark:text-jcm-cream mb-4">
          {t.sustainability.items[2].title}
        </h3>
        <p data-i18="sustainability.item2.desc" class="font-body text-[var(--text-primary)]">
          {t.sustainability.items[2].description}
        </p>
      </div>
    </div>
  </div>
</section>
