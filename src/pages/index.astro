---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Business from "../components/Business.astro";
import Projects from "../components/Projects.astro";
import Sustainability from "../components/Sustainability.astro";
import People from "../components/People.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="JCM Inc - Joint Constructions Magnament International">
  <Header lang="es" />
  <Hero lang="es" />
  <About lang="es" />
  <Business lang="es" />
  <Projects lang="es" />
  <Sustainability lang="es" />
  <People lang="es" />
  <Contact lang="es" />
  <Footer lang="es" />
</Layout>

<script>
  const stored = localStorage.getItem("jcm-theme");
  const state = stored ? JSON.parse(stored) : { theme: "light", language: "es" };
  
  if (state.theme === "dark") {
    document.documentElement.classList.add("dark");
  }
</script>
